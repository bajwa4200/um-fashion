# Database
DATABASE_URL="postgresql://um:um_secret@127.0.0.1:5432/um_marketplace?sslmode=disable"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="um-fashion-dev-secret-change-in-production-abc123xyz"

# Stripe Connect
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# MinIO / S3
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin123"
S3_BUCKET="um-uploads"
S3_REGION="us-east-1"
S3_PUBLIC_URL="http://localhost:9000/um-uploads"

# Vercel client demo — marketplace only, no GPU (set on Vercel production)
NEXT_PUBLIC_DEMO_MODE="false"

# AI Service (CPU fallback when GPU laptop not used — local dev only)
AI_SERVICE_URL="http://localhost:8000"

# GPU Laptop (RTX 4060) — tunnel URL when deployed; local http://127.0.0.1:8100 for dev
GPU_WORKER_URL="http://127.0.0.1:8100"
GPU_WORKER_SECRET="change-me-gpu-secret"

# Upstash Redis (Vercel job queue) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Vercel Blob (avatar GLB / thumbnails in production)
BLOB_READ_WRITE_TOKEN=""

OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"
OLLAMA_EMBED_MODEL="nomic-embed-text"

# Photorealistic 3D human (Replicate) — get token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=""
REPLICATE_MODEL="fofr/instant-mesh"
HUMAN_RECON_BACKEND="auto"

# Redis
REDIS_URL="redis://localhost:6379"

# Platform
DEFAULT_COMMISSION_RATE="0.15"
