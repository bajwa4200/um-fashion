# Copy to services/ai/.env or set in repo root .env

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=um-uploads
S3_PUBLIC_URL=http://localhost:9000/um-uploads

# Photorealistic 3D (optional) — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_MODEL=fofr/instant-mesh
HUMAN_RECON_BACKEND=auto

# Set UVICORN_RELOAD=1 only if you need hot reload (can be unstable on Windows)
# UVICORN_RELOAD=0
